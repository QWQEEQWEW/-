    def save_profile(self):
        name = self.e_new_prof.text() or self.c_prof.currentText()
        if not name or "---" in name: return
        data = {
            'win_name': self.e_win_name.text(), 'win_capture': self.chk_win_capture.isChecked(),
            'mode': 'ai' if self.mode_ai.isChecked() else ('pixel' if self.mode_pixel.isChecked() else 'cursor'),
            'nn_model': self.e_nn_model_path.text(), 'nn_conf': self.s_nn_conf.value(),
            'nn_offx': self.s_nn_offset_x.value(), 'nn_offy': self.s_nn_offset_y.value(),
            'imgsz': self.nn_imgsz, 'show_fps_overlay': self.chk_show_fps_overlay.isChecked(),
            'debug_fps': self.s_debug_fps.value(),
            'mana_reg': [self.mana_region.left(), self.mana_region.top(), self.mana_region.width(),
                         self.mana_region.height()] if self.mana_region else None,
            'skills': [{'off_x': s.off_x, 'off_y': s.off_y, 'points': s.points, 'key': s.edit_key.text(),
                        'mana': s.mana_cost.value(), 'reg': [s.region.left(), s.region.top(), s.region.width(),
                                                             s.region.height()] if s.region else None} for s in
                       self.skills],
            'combos': [
                {'trigger': r.trigger_mode.currentText(), 'key': r.btn_key.key, 'tracking': r.chk_tracking.isChecked(),
                 'cond': r.condition_mode.currentText(), 'steps': r.steps} for r in self.findChildren(ComboRow)]
        }
        with open(os.path.join(PROFILES_DIR, f"{name}.json"), 'w', encoding='utf-8') as f: json.dump(data, f, indent=4)
        self.refresh_profiles_list()

    def load_profile(self):
        # 🔧 FIX: останавливаем потоки перед модификацией UI, чтобы избежать гонки
        was_active = self.is_active
        if was_active:
            self.is_active = False  # временно выключаем логику

        if self.c_prof.currentIndex() <= 0:
            if was_active: self.is_active = True
            return

        path = os.path.join(PROFILES_DIR, f"{self.c_prof.currentText()}.json")
        try:
            with open(path, 'r', encoding='utf-8') as f:
                data = json.load(f)
            self.e_win_name.setText(data.get('win_name', ''));
            self.chk_win_capture.setChecked(data.get('win_capture', False))
            self.e_nn_model_path.setText(data.get('nn_model', ''));
            self.s_nn_conf.setValue(data.get('nn_conf', 40))
            self.s_nn_offset_x.setValue(data.get('nn_offx', 0));
            self.s_nn_offset_y.setValue(data.get('nn_offy', 40))
            self.nn_imgsz = data.get('imgsz', 1280);
            self.cb_imgsz.setCurrentText(str(self.nn_imgsz))
            self.chk_show_fps_overlay.setChecked(data.get('show_fps_overlay', False))
            debug_fps = data.get('debug_fps', 60)
            self.s_debug_fps.setValue(debug_fps)
            self.s_debug_fps.setSuffix("" if debug_fps == 0 else " FPS")
            if hasattr(self, 'debug_renderer'): self.debug_renderer.update_fps_limit(debug_fps)
            if data.get('mana_reg'): self.mana_region = QRect(*data['mana_reg'])

            # 🔧 FIX: безопасно удаляем скиллы — сначала снимаем с layout, потом deleteLater
            with self.skills_lock:
                for s in self.skills:
                    if s.parent(): s.setParent(None)  # убираем из layout
                    s.deleteLater()
                self.skills.clear()
                # Даём время на обработку deleteLater
                QApplication.processEvents()

            for s_d in data.get('skills', []): self.add_skill_ui(s_d)

            for r in self.findChildren(ComboRow):
                if r.parent(): r.setParent(None)
                r.deleteLater()
            QApplication.processEvents()

            for c_d in data.get('combos', []): self.c_layout.addWidget(ComboRow(self, c_d))

        except Exception as e:
            print(f"[❌] Ошибка загрузки профиля: {e}")
        finally:
            # 🔧 Восстанавливаем состояние активности
            if was_active:
                QTimer.singleShot(100, lambda: setattr(self, 'is_active', True))

    def refresh_profiles_list(self):
        self.c_prof.clear();
        self.c_prof.addItems(
            ["--- Профиль ---"] + [f.replace(".json", "") for f in os.listdir(PROFILES_DIR) if f.endswith(".json")])


class RegionSelector(QWidget):
    def __init__(self, cb):
        super().__init__();
        self.cb, self.origin = cb, QPoint()
        self.setWindowFlags(Qt.WindowType.FramelessWindowHint | Qt.WindowType.WindowStaysOnTopHint | Qt.WindowType.Tool)
        self.setWindowOpacity(0.3);
        self.setStyleSheet("background:black;");
        self.showFullScreen()
        self.rb = QRubberBand(QRubberBand.Shape.Rectangle, self)

    def mousePressEvent(self, e): self.origin = e.pos(); self.rb.setGeometry(
        QRect(self.origin, self.origin)); self.rb.show()

    def mouseMoveEvent(self, e): self.rb.setGeometry(QRect(self.origin, e.pos()).normalized())

    def mouseReleaseEvent(self, e): self.cb(self.rb.geometry()); self.close()


