class ZoneTrackerThread(QThread):
    def __init__(self, mw):
        super().__init__()
        self.mw, self.running, self.zone_state = mw, True, ZoneState()

    def run(self):
        while self.running:
            if not self.mw.is_active:
                time.sleep(0.001)
                continue
            tracking_disabled = getattr(self.mw, '_tracking_disabled', False)
            t_pos = None
            if self.mw.mode_cursor.isChecked():
                cp = QCursor.pos()
                t_pos = [cp.x(), cp.y()]
            elif not tracking_disabled and hasattr(self.mw, 'detector'):
                # 🔧 Читаем из атомарного снэпшота
                snapshot = getattr(self.mw.detector, '_latest_snapshot', None)
                if snapshot and (time.perf_counter() - snapshot['ts'] < 0.15) and snapshot['target']:
                    t_pos = snapshot['target'].copy()
            sc = self.mw.overlay.screen().geometry().center()
            zones = {}
            with self.mw.skills_lock:
                for idx, sk in enumerate(self.mw.skills):
                    zones[idx] = self.check_point_in_polygon(t_pos, sk, sc) if t_pos and sk.points else False
                    sk.is_target_in = zones[idx]
            self.zone_state.update(t_pos, zones)
            time.sleep(0.0005)

    def check_point_in_polygon(self, pt, sk, sc):
        if not pt: return False
        cx, cy, n, inside = sc.x() + sk.off_x, sc.y() + sk.off_y, len(sk.points), False
        j = n - 1
        for i in range(n):
            xi, yi = cx + sk.points[i][0], cy + sk.points[i][1]
            xj, yj = cx + sk.points[j][0], cy + sk.points[j][1]
            if ((yi > pt[1]) != (yj > pt[1])) and (
                    pt[0] < (xj - xi) * (pt[1] - yi) / ((yj - yi) if (yj - yi) != 0 else 1e-9) + xi):
                inside = not inside
            j = i
        return inside


class LogicThread(QThread):
    def __init__(self, mw, zone_tracker):
        super().__init__()
        self.mw, self.zone_tracker, self.running = mw, zone_tracker, True
        self.cur_mana, self.mana_updated, self.combo_states = 0, False, {}
        self.tracking_active = False

    def is_bind_pressed(self, key):
        k = key.lower()
        if k == "x": return (ctypes.windll.user32.GetAsyncKeyState(0x05) & 0x8000) != 0
        if k == "x2": return (ctypes.windll.user32.GetAsyncKeyState(0x06) & 0x8000) != 0
        try:
            return keyboard.is_pressed(k)
        except:
            return False

    def run(self):
        while self.running:
            if not self.mw.is_active: self.msleep(10); continue
            combos = self.mw.findChildren(ComboRow)
            self.tracking_active = any(self.is_bind_pressed(row.btn_key.key) for row in combos)

            for row in combos:
                rid = id(row)
                if rid not in self.combo_states: self.combo_states[rid] = {"was_p": False, "tgl": False,
                                                                           "running": False}
                st = self.combo_states[rid]
                is_p = self.is_bind_pressed(row.btn_key.key)
                if st["running"]: continue
                if row.trigger_mode.currentText() == "Hold" and is_p:
                    st["running"] = True
                    self.execute_combo(row)
                    st["running"] = False
                elif row.trigger_mode.currentText() == "Toggle":
                    if is_p and not st["was_p"]: st["tgl"] = not st["tgl"]
                    if st["tgl"]:
                        st["running"] = True
                        res = self.execute_combo(row)
                        if res in ["STOP", "FAIL", "NO_TARGET"]: st["tgl"] = False
                        st["running"] = False
                st["was_p"] = is_p
            self.msleep(1)

    def execute_combo(self, row):
        steps = list(row.steps)
        if not steps: return "FAIL"
        _, pos, zones, _ = self.zone_tracker.zone_state.snapshot()
        if not pos: return "NO_TARGET"
        if row.chk_tracking.isChecked() and not getattr(self.mw, '_tracking_disabled', False):
            mouse.move(int(pos[0]), int(pos[1]), absolute=True)
        cond = row.condition_mode.currentText()
        if cond == "Ренж 1-го" and not zones.get(steps[0]['skill_idx'], False): return "OUT"
        if cond == "Ренж любого" and not any(zones.get(s['skill_idx'], False) for s in steps): return "OUT"
        lock_pos = None
        for step_idx, s in enumerate(steps):
            if row.trigger_mode.currentText() == "Hold" and not self.is_bind_pressed(row.btn_key.key): return "STOP"
            idx = s['skill_idx']
            with self.mw.skills_lock:
                if idx >= len(self.mw.skills): continue
                sk = self.mw.skills[idx]
            _, live_p, live_zones, _ = self.zone_tracker.zone_state.snapshot()
            cur_p = live_p if live_p else pos
            if s.get('use_range') and not live_zones.get(idx): return "OUT"
            if s.get('disable_tracking', False):
                self.mw._tracking_disabled = True
            if s['action'] == "🎯 Довести до края":
                sc = self.mw.overlay.screen().geometry().center()
                pivot = [sc.x() + sk.off_x, sc.y() + sk.off_y]
                aim = lock_pos if (lock_pos or s.get('disable_tracking', False)) else cur_p
                res = self.mw.intersect_ray_polygon(pivot, aim, sk.points)
                mouse.move(int(res[0]), int(res[1]), absolute=True)
            else:
                if s.get('lock_pos') and cur_p: lock_pos = list(cur_p)
                keyboard.press_and_release(sk.edit_key.text().lower())
            delay = s['delay']
            if delay > 0:
                start_t = time.time()
                while (time.time() - start_t) * 1000 < delay:
                    if row.trigger_mode.currentText() == "Hold" and not self.is_bind_pressed(row.btn_key.key):
                        if s.get('disable_tracking', False): self.mw._tracking_disabled = False
                        return "STOP"
                    if s.get('can_cancel'):
                        elapsed = (time.time() - start_t) * 1000
                        if elapsed <= s.get('cancel_window_ms', 120):
                            if not s.get('disable_tracking', False):
                                cursor = QCursor.pos()
                                # 🔧 Читаем из снэпшота
                                snapshot = getattr(self.mw.detector, '_latest_snapshot', None)
                                if snapshot and (time.perf_counter() - snapshot['ts'] < 0.1) and snapshot['target']:
                                    target = snapshot['target']
                                    dist = math.hypot(cursor.x() - target[0], cursor.y() - target[1])
                                    if dist > s.get('cancel_range_px', 50):
                                        keyboard.press_and_release('s')
                                        if s.get('disable_tracking', False): self.mw._tracking_disabled = False
                                        return "CANCELLED"
                    time.sleep(0.001)
            if s.get('disable_tracking', False):
                next_step_disables = (step_idx + 1 < len(steps) and steps[step_idx + 1].get('disable_tracking', False))
                if not next_step_disables: self.mw._tracking_disabled = False
        self.mw._tracking_disabled = False
        return "OK"


# 🔧 DetectorThread с единым атомарным снэпшотом для ВСЕХ читателей
class DetectorThread(QThread):
    coords_updated = pyqtSignal(list, float)

    def __init__(self, mw):
        super().__init__()
        self.mw = mw
        self.running = True
        self.model = None
        self.device = 'cuda' if YOLO and torch.cuda.is_available() else 'cpu'
        self.debug_buffer = ThreadSafeBuffer(max_size=2)
        self.target_point = None
        self.target_timestamp = 0.0
        self._coord_lock = threading.Lock()
        self.fps_counter = 0
        self.last_fps_time = time.time()
        self.current_fps = 0
        self.all_detections = []
        self.alpha = 0.35
        self.locked_center = None
        self.track_radius = 120
        self._model_lock = threading.Lock()
        # 🔧 ЕДИНЫЙ снэпшот для оверлея, дебаг-рендера и логики
        self._latest_snapshot = {
            'target': None,
            'ts': 0.0,
            'detections': [],
            'version': 0  # монотонный счётчик для проверки актуальности
        }

    def run(self):
        while self.running:
            try:
                capture_rect = self.mw.overlay.screen().geometry()
                ratio = self.mw.devicePixelRatio()
                full_frame = self.mw.grabber.grab_bgr(capture_rect, ratio)

                if full_frame is None or full_frame.size == 0:
                    continue

                h, w = full_frame.shape[:2]
                if w == 0 or h == 0:
                    continue

                scale = self.mw.nn_imgsz / w
                new_h = int(h * scale)
                inference_frame = cv2.resize(full_frame, (self.mw.nn_imgsz, new_h), interpolation=cv2.INTER_LINEAR)

                detections = []
                cursor = QCursor.pos()
                raw_center = None

                if self.mw.mode_ai.isChecked() and YOLO and self.mw.e_nn_model_path.text():
                    m_path = self.mw.e_nn_model_path.text()
                    if not self.model or getattr(self.model, 'pt_path', '') != m_path:
                        try:
                            with self._model_lock:
                                self.model = YOLO(m_path).to(self.device)
                                self.model.pt_path = m_path
                        except Exception as e:
                            print(f"[❌] Ошибка загрузки модели: {e}")
                            self.model = None
                            time.sleep(0.2)
                            continue

                    if self.model:
                        conf = self.mw.s_nn_conf.value() / 100.0
                        try:
                            with torch.inference_mode():
                                results = self.model(inference_frame, verbose=False, conf=conf, device=self.device)
                            if results and results[0].boxes is not None:
                                boxes = results[0].boxes.xyxy.cpu().numpy()
                                confs = results[0].boxes.conf.cpu().numpy()
                                for i, (x1, y1, x2, y2) in enumerate(boxes):
                                    x1_g = capture_rect.left() + (x1 / scale) / ratio
                                    y1_g = capture_rect.top() + (y1 / scale) / ratio
                                    x2_g = capture_rect.left() + (x2 / scale) / ratio
                                    y2_g = capture_rect.top() + (y2 / scale) / ratio
                                    detections.append({
                                        'center': ((x1_g + x2_g) / 2, (y1_g + y2_g) / 2),
                                        'bbox': (x1_g, y1_g, x2_g, y2_g),
                                        'conf': float(confs[i]),
                                        'bbox_local': (int(x1), int(y1), int(x2), int(y2))
                                    })
                        except Exception as e:
                            err_str = str(e).lower()
                            if "cuda" in err_str or "access" in err_str:
                                print(f"[⚠️] GPU/Access ошибка: {e}")
                                torch.cuda.empty_cache()
                                self.model = None
                            time.sleep(0.005)

                tracking_engaged = getattr(self.mw.logic, 'tracking_active', False)
                if tracking_engaged:
                    if self.locked_center is None:
                        best = min(detections,
                                   key=lambda d: math.hypot(d['center'][0] - cursor.x(), d['center'][1] - cursor.y()),
                                   default=None)
                        if best: self.locked_center, raw_center = best['center'], best['center']
                    else:
                        best = min(detections, key=lambda d: math.hypot(d['center'][0] - self.locked_center[0],
                                                                        d['center'][1] - self.locked_center[1]),
                                   default=None)
                        if best and math.hypot(best['center'][0] - self.locked_center[0],
                                               best['center'][1] - self.locked_center[1]) < self.track_radius:
                            cx, cy = best['center']
                            self.locked_center = (self.alpha * cx + (1.0 - self.alpha) * self.locked_center[0],
                                                  self.alpha * cy + (1.0 - self.alpha) * self.locked_center[1])
                            raw_center = self.locked_center
                        else:
                            raw_center = self.locked_center
                else:
                    self.locked_center = None
                    best = min(detections,
                               key=lambda d: math.hypot(d['center'][0] - cursor.x(), d['center'][1] - cursor.y()),
                               default=None)
                    if best: raw_center = best['center']

                target_point = [raw_center[0] + self.mw.s_nn_offset_x.value(),
                                raw_center[1] + self.mw.s_nn_offset_y.value()] if raw_center else None
                ts = time.perf_counter()

                # 🔧 АТОМАРНОЕ обновление: всё в одной блокировке
                with self._coord_lock:
                    self.target_point = target_point
                    self.target_timestamp = ts
                    self.all_detections = detections
                    # Обновляем снэпшот с инкрементом версии
                    self._latest_snapshot = {
                        'target': target_point.copy() if target_point else None,
                        'ts': ts,
                        'detections': [d.copy() for d in detections],
                        'version': self._latest_snapshot['version'] + 1
                    }

                if target_point: self.coords_updated.emit(target_point, ts)

                # 🔧 В debug_buffer кладём ТОЛЬКО ссылку на версию снэпшота, а не копию данных
                if self.mw.debug_win and self.mw.debug_win.isVisible():
                    self.debug_buffer.put({
                        'frame': inference_frame,
                        'snapshot_version': self._latest_snapshot['version'],  # ссылка на версию
                        'scale': scale,
                        'capture_rect_left': capture_rect.left(),
                        'capture_rect_top': capture_rect.top(),
                        'ratio': ratio
                    })

                self.fps_counter += 1
                now = time.time()
                if now - self.last_fps_time >= 1.0:
                    self.current_fps, self.fps_counter, self.last_fps_time = self.fps_counter, 0, now

            except Exception as e:
                print(f"[❌] Ошибка в DetectorThread: {e}")
                time.sleep(0.002)


# 🔧 DebugRendererThread читает из того же снэпшота по версии
class DebugRendererThread(QThread):
    frame_ready = pyqtSignal(QImage)

    def __init__(self, mw, detector):
        super().__init__()
        self.mw, self.detector, self.running = mw, detector, True
        self.debug_fps_limit = 60
        self._last_debug_time = 0

    def update_fps_limit(self, value):
        self.debug_fps_limit = max(0, value)

    def run(self):
        while self.running:
            now = time.time()
            if not (self.mw.debug_win and self.mw.debug_win.isVisible()):
                time.sleep(0.05)
                continue
            if self.debug_fps_limit > 0:
                if (now - self._last_debug_time) < (1.0 / self.debug_fps_limit):
                    time.sleep(0.001)
                    continue

            data = self.detector.debug_buffer.get_latest()
            if not data or data['frame'] is None:
                continue

            # 🔧 Читаем снэпшот по версии из буфера — гарантия синхронизации
            snapshot = None
            with self.detector._coord_lock:
                if self.detector._latest_snapshot['version'] == data.get('snapshot_version'):
                    snapshot = self.detector._latest_snapshot.copy()

            if not snapshot:
                continue  # версия устарела, пропускаем кадр

            dbg_frame = self._render_debug_frame(data, snapshot)
            h, w, c = dbg_frame.shape
            self.frame_ready.emit(QImage(dbg_frame.data, w, h, w * c, QImage.Format.Format_BGR888).copy())
            self._last_debug_time = now
            if self.debug_fps_limit > 0:
                time.sleep(0.001)

    def _render_debug_frame(self, data, snapshot):
        frame, scale = data['frame'].copy(), data['scale']
        ratio = data.get('ratio', 1.0)

        # Рисуем детекции из снэпшота
        for det in snapshot['detections']:
            x1, y1, x2, y2 = det['bbox_local']
            cv2.rectangle(frame, (x1, y1), (x2, y2), (0, 255, 0), 1)

        # 🔧 Рисуем крестик из ТОГО ЖЕ снэпшота
        if snapshot['target']:
            tx_local = int(((snapshot['target'][0] - data['capture_rect_left']) * ratio) * scale)
            ty_local = int(((snapshot['target'][1] - data['capture_rect_top']) * ratio) * scale)
            cv2.drawMarker(frame, (tx_local, ty_local), (0, 0, 255), cv2.MARKER_CROSS, 20, 2)

        cv2.putText(frame, f"DetFPS: {self.detector.current_fps}", (10, 20), cv2.FONT_HERSHEY_SIMPLEX, 0.6,
                    (0, 255, 255), 2)
        dbg_fps = int(1.0 / (time.time() - self._last_debug_time + 0.001)) if self._last_debug_time > 0 else 0
        cv2.putText(frame, f"DbgFPS: {dbg_fps}", (10, 40), cv2.FONT_HERSHEY_SIMPLEX, 0.6, (255, 255, 0), 2)
        return frame

    def stop(self):
        self.running = False


class RangeOverlay(QWidget):
    def __init__(self, mw):
        super().__init__()
        self.mw, self.drag_pt, self.active_sk = mw, None, None
        self.setWindowFlags(
            Qt.WindowType.FramelessWindowHint | Qt.WindowType.WindowStaysOnTopHint | Qt.WindowType.Tool | Qt.WindowType.WindowTransparentForInput)
        self.setAttribute(Qt.WidgetAttribute.WA_TranslucentBackground)
        self.showFullScreen()
        QTimer.singleShot(500, self.apply_protection)

    def apply_protection(self):
        try:
            ctypes.windll.user32.SetWindowDisplayAffinity(wintypes.HWND(int(self.winId())), WDA_EXCLUDEFROMCAPTURE)
        except:
            pass

    def set_interactivity(self, sk, en):
        self.active_sk = sk
        f = Qt.WindowType.FramelessWindowHint | Qt.WindowType.WindowStaysOnTopHint | Qt.WindowType.Tool
        if not en: f |= Qt.WindowType.WindowTransparentForInput
        self.setWindowFlags(f)
        self.showFullScreen()

    def paintEvent(self, e):
        p = QPainter(self)
        p.setRenderHint(QPainter.RenderHint.Antialiasing)
        sc = self.screen().geometry().center()
        with self.mw.skills_lock:
            for sk in self.mw.skills:
                if not sk.check_show.isChecked() and not sk.check_edit.isChecked(): continue
                cx, cy = sc.x() + sk.off_x, sc.y() + sk.off_y
                path = QPainterPath()
                pts = [QPointF(cx + pt[0], cy + pt[1]) for pt in sk.points]
                if not pts: continue
                path.moveTo((pts[0] + pts[7]) / 2)
                for i in range(8): path.quadTo(pts[i], (pts[i] + pts[(i + 1) % 8]) / 2)
                path.closeSubpath()
                color = QColor(201, 160, 99) if sk.check_edit.isChecked() else (
                    QColor(0, 255, 0, 80) if sk.is_target_in else QColor(0, 168, 232, 50))
                p.setPen(QPen(color, 2))
                p.setBrush(QColor(color.red(), color.green(), color.blue(), 20))
                p.drawPath(path)
                if sk.check_edit.isChecked():
                    for pt in pts: p.drawEllipse(pt, 5, 5)

        # 🔧 Читаем из того же атомарного снэпшота
        if hasattr(self.mw, 'detector') and self.mw.detector.isRunning():
            snapshot = None
            with self.mw.detector._coord_lock:
                # Берём снэпшот, если он свежий (<50 мс)
                if (time.perf_counter() - self.mw.detector._latest_snapshot['ts']) < 0.05:
                    snapshot = self.mw.detector._latest_snapshot.copy()

            if snapshot and snapshot['target']:
                tp = snapshot['target']
                p.setPen(Qt.PenStyle.NoPen)
                p.setBrush(QColor(255, 0, 255))
                p.drawEllipse(QPointF(tp[0], tp[1]), 6, 6)

            if self.mw.chk_show_fps_overlay.isChecked():
                font = QFont("Segoe UI", 16, QFont.Weight.Bold)
                p.setFont(font)
                p.setPen(QColor(0, 255, 0))
                p.drawText(50, 80, f"DETECTION FPS: {self.mw.detector.current_fps}")

    def mousePressEvent(self, e):
        if not self.active_sk: return
        sc, sk, mp = self.screen().geometry().center(), self.active_sk, e.position()
        cx, cy = sc.x() + sk.off_x, sc.y() + sk.off_y
        if (mp - QPointF(cx, cy)).manhattanLength() < 20:
            self.drag_pt = "center"
        else:
            for i, p in enumerate(sk.points):
                if (mp - QPointF(cx + p[0], cy + p[1])).manhattanLength() < 15: self.drag_pt = i; break

    def mouseMoveEvent(self, e):
        if self.drag_pt is None or not self.active_sk: return
        sc, sk, mp = self.screen().geometry().center(), self.active_sk, e.position()
        if self.drag_pt == "center":
            sk.off_x, sk.off_y = int(mp.x() - sc.x()), int(mp.y() - sc.y())
        else:
            sk.points[self.drag_pt] = [int(mp.x() - (sc.x() + sk.off_x)), int(mp.y() - (sc.y() + sk.off_y))]

    def mouseReleaseEvent(self, e):
        self.drag_pt = None


