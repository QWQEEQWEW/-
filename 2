# === ScreenGrabber ===
class ScreenGrabber(QThread):
    def __init__(self, mw):
        super().__init__()
        self.mw, self.running = mw, True
        self._lock = threading.Lock()
        self._last_frame = None
        self.camera = None
        self._init_dxcam()

    def _init_dxcam(self):
        if dxcam is None:
            print("[⚠️] dxcam не установлен, захват отключён")
            return
        try:
            self.camera = dxcam.create(device_idx=0, output_idx=0, output_color="BGR")
            self.camera.start(target_fps=0)
            print(f"[✓] dxcam запущен в BGR (макс. FPS)")
        except Exception as e:
            print(f"[❌] Ошибка инициализации dxcam: {e}")
            try:
                self.camera = dxcam.create(device_idx=0, output_idx=0)
                self.camera.start(target_fps=0)
                print(f"[✓] dxcam запущен (fallback)")
            except Exception as e2:
                print(f"[❌] Не удалось запустить dxcam: {e2}")
                self.camera = None

    def run(self):
        while self.running:
            if self.camera is None:
                time.sleep(0.001)
                continue
            try:
                frame = self.camera.get_latest_frame()
                if frame is not None:
                    with self._lock:
                        self._last_frame = frame
            except Exception as e:
                print(f"[⚠️] Ошибка захвата: {e}")
                time.sleep(0.01)
            time.sleep(0)

    def grab_bgr(self, rect: QRect, ratio: float) -> np.ndarray | None:
        with self._lock:
            base = self._last_frame
            if base is None:
                return None
            x1 = int(max(0, rect.left() * ratio))
            y1 = int(max(0, rect.top() * ratio))
            x2 = int(min(base.shape[1], (rect.left() + rect.width()) * ratio))
            y2 = int(min(base.shape[0], (rect.top() + rect.height()) * ratio))
            if x2 <= x1 or y2 <= y1:
                return None
            return base[y1:y2, x1:x2].copy()

    def stop(self):
        self.running = False
        if self.camera:
            try:
                self.camera.stop()
            except:
                pass


class ZoneState:
    def __init__(self):
        self._lock, self._zones, self._target_pos, self._ts, self._ver = threading.Lock(), {}, None, 0.0, 0

    def update(self, target_pos, zones_dict):
        with self._lock:
            self._target_pos = list(target_pos) if target_pos else None
            self._zones = dict(zones_dict)
            self._ts = time.monotonic()
            self._ver += 1

    def snapshot(self):
        with self._lock:
            return self._ver, (self._target_pos.copy() if self._target_pos else None), self._zones.copy(), self._ts


class HotkeyButton(QPushButton):
    def __init__(self, def_key, parent=None):
        super().__init__(parent)
        self.key, self.k_hook, self.m_hook = def_key, None, None
        self.setText(self.key.upper())
        self.setFixedWidth(60)
        self.clicked.connect(self.start_recording)

    def start_recording(self):
        self.setText("???")
        self.k_hook = keyboard.on_press(self.save_key)
        self.m_hook = mouse.on_button(self.save_mouse, buttons=(mouse.X, mouse.X2), types=(mouse.DOWN,))

    def save_key(self, e):
        self.finalize_recording(e.name)

    def save_mouse(self):
        self.finalize_recording("x" if mouse.is_pressed(mouse.X) else "x2")

    def finalize_recording(self, kn):
        self.key = kn
        self.setText(kn.upper())
        try:
            if self.k_hook: keyboard.unhook(self.k_hook)
        except:
            pass
        try:
            if self.m_hook: mouse.unhook(self.m_hook)
        except:
            pass
        self.k_hook = self.m_hook = None


