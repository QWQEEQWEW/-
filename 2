    def add_skill_ui(self, d=None):
        with self.skills_lock:
            w = SkillWidget(len(self.skills) + 1, self, d);
            self.s_layout.addWidget(w, len(self.skills) // 2, len(self.skills) % 2)
            self.skills.append(w)

    def run_ocr(self):
        if self.mana_region:
            bgr = self.grabber.grab_bgr(self.mana_region, self.devicePixelRatio())
            if bgr is not None:
                gray = cv2.cvtColor(bgr, cv2.COLOR_BGR2GRAY)
                text = pytesseract.image_to_string(gray,
                                                   config='--psm 7 -c tessedit_char_whitelist=0123456789/').strip()
                val = text.split('/')[0] if '/' in text else text
                if val.isdigit(): self.logic.cur_mana = int(val); self.mana_val.setText(val)
                # 🔧 FIX: QPixmap, а не Pixmap
                self.mana_view.setPixmap(
                    QPixmap.fromImage(QImage(bgr.data, bgr.shape[1], bgr.shape[0], QImage.Format.Format_BGR888)).scaled(
                        self.mana_view.size()))

    def run_scan(self):
        if not self.is_active: return
        with self.skills_lock:
            for sk in self.skills:
                if sk.region and sk.ready_img is not None:
                    curr_bgr = self.grabber.grab_bgr(sk.region, self.devicePixelRatio())
                    if curr_bgr is not None:
                        templ = sk.get_ready_img_copy()
                        if templ is not None and curr_bgr.shape[0] >= templ.shape[0]:
                            res = cv2.matchTemplate(curr_bgr, templ, cv2.TM_CCOEFF_NORMED);
                            _, val, _, _ = cv2.minMaxLoc(res)
                            sk.apply_cd_ui(val > 0.9, val)

    def update_ui(self):
        self.overlay.update()
        if self.chk_h.isChecked() and keyboard.is_pressed(self.btn_h.key): self.toggle_status(); time.sleep(0.3)
        data_list = []
        for row in self.findChildren(ComboRow):
            if self.logic.is_bind_pressed(row.btn_key.key) or self.logic.combo_states.get(id(row), {}).get("tgl"):
                req, ready = 0, True
                for s in row.steps:
                    with self.skills_lock:
                        if s['skill_idx'] < len(self.skills):
                            sk = self.skills[s['skill_idx']];
                            req += sk.mana_cost.value()
                            if not sk.is_ready: ready = False
                data_list.append({"name": f"Combo {row.btn_key.key.upper()}", "current_mana": self.logic.cur_mana,
                                  "required_mana": req, "cd_ready": ready})
        self.active_combos_ui.update_active_combos(data_list)

    def intersect_ray_polygon(self, pivot, target, poly):
        rdx, rdy = target[0] - pivot[0], target[1] - pivot[1]
        dist = math.sqrt(rdx ** 2 + rdy ** 2)
        if dist < 1: return target
        for i in range(len(poly)):
            p1 = [pivot[0] + poly[i][0], pivot[1] + poly[i][1]];
            p2 = [pivot[0] + poly[(i + 1) % len(poly)][0], pivot[1] + poly[(i + 1) % len(poly)][1]]
            v1, v2, v3 = [pivot[0] - p1[0], pivot[1] - p1[1]], [p2[0] - p1[0], p2[1] - p1[1]], [-rdy, rdx]
            dot = v2[0] * v3[0] + v2[1] * v3[1]
            if abs(dot) > 1e-6:
                t1 = (v2[0] * v1[1] - v2[1] * v1[0]) / dot;
                t2 = (v1[0] * v3[0] + v1[1] * v3[1]) / dot
                if t1 >= 0 and 0 <= t2 <= 1: return [pivot[0] + t1 * rdx, pivot[1] + t1 * rdy]
        return target

